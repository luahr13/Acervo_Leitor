@model Acervo_Leitor.Models.Aluno

@{
    ViewData["Title"] = "Editar Aluno";
}

<div class="form-container">
    <div class="detail-header">
        <h1>Editar Aluno</h1>
    </div>

    <div class="form-card">
        <h4>👨‍🎓 Aluno</h4>
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <input type="hidden" asp-for="Id" />
            
            <div class="form-group">
                <label asp-for="Nome" class="control-label">Nome</label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="TurmaId" class="control-label">Turma</label>
                <select asp-for="TurmaId" class="form-control" asp-items="ViewBag.TurmaId"></select>
                <span asp-validation-for="TurmaId" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="Telefone" class="control-label">Telefone</label>
                <input asp-for="Telefone" class="form-control" />
                <span asp-validation-for="Telefone" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <div class="form-check">
                    <input class="form-check-input" asp-for="Ativo" />
                    <label class="form-check-label" asp-for="Ativo">
                        @Html.DisplayNameFor(model => model.Ativo)
                    </label>
                </div>
            </div>
            
            <div class="action-buttons-footer">
                <button type="submit" class="btn btn-sm btn-save-subtle">
                    Salvar
                </button>
                <a asp-action="Index" class="btn btn-sm btn-clear-subtle">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
