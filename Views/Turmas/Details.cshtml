@model Acervo_Leitor.Models.Turma

@{
    ViewData["Title"] = "Detalhes da Turma";
}

<div class="detail-container">
    <div class="detail-header">
        <h1>Detalhes da Turma</h1>
    </div>

    <div class="detail-card">
        <h4>📚 Turma</h4>
        <div class="detail-list">
            <div class="detail-item">
                <div class="detail-label">@Html.DisplayNameFor(model => model.Nome)</div>
                <div class="detail-value">@Html.DisplayFor(model => model.Nome)</div>
            </div>
            <div class="detail-item">
                <div class="detail-label">@Html.DisplayNameFor(model => model.AnoLetivo)</div>
                <div class="detail-value">@Html.DisplayFor(model => model.AnoLetivo)</div>
            </div>
            <div class="detail-item">
                <div class="detail-label">@Html.DisplayNameFor(model => model.Ativa)</div>
                <div class="detail-value">
                    @if (Model?.Ativa == true)
                    {
                        <span class="badge bg-success">Ativa</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inativa</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="action-buttons-footer">
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-sm btn-edit-subtle">
            Editar
        </a>
        <a asp-action="Index" class="btn btn-sm btn-clear-subtle">
            Voltar
        </a>
    </div>
</div>
