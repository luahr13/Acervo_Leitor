@model Acervo_Leitor.Models.Livro

@{
    ViewData["Title"] = "Detalhes do Livro";
}

<div class="detail-container">
    <div class="detail-header">
        <h1>Detalhes do Livro</h1>
    </div>

    <div class="detail-card">
        <h4>📚 Livro</h4>
        <div class="detail-list">
            <div class="detail-item">
                <div class="detail-label">@Html.DisplayNameFor(model => model.Titulo)</div>
                <div class="detail-value">@Html.DisplayFor(model => model.Titulo)</div>
            </div>
            <div class="detail-item">
                <div class="detail-label">@Html.DisplayNameFor(model => model.Autor)</div>
                <div class="detail-value">@Html.DisplayFor(model => model.Autor)</div>
            </div>
            <div class="detail-item">
                <div class="detail-label">@Html.DisplayNameFor(model => model.CodigoExemplar)</div>
                <div class="detail-value">@Html.DisplayFor(model => model.CodigoExemplar)</div>
            </div>
            <div class="detail-item">
                <div class="detail-label">@Html.DisplayNameFor(model => model.Ativo)</div>
                <div class="detail-value">
                    @if (Model?.Ativo == true)
                    {
                        <span class="badge bg-success">Ativo</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inativo</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="action-buttons-footer">
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-sm btn-edit-subtle">
            Editar
        </a>
        <a asp-action="Index" class="btn btn-sm btn-clear-subtle">
            Voltar
        </a>
    </div>
</div>
