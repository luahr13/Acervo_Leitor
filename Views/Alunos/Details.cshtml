@model Acervo_Leitor.Models.Aluno

@{
    ViewData["Title"] = "Detalhes do Aluno";
}

<div class="detail-container">
    <div class="detail-header">
        <h1>Detalhes do Aluno</h1>
    </div>

    <div class="detail-card">
        <h4>👨‍🎓 Aluno</h4>
        <div class="detail-list">
            <div class="detail-item">
                <div class="detail-label">@Html.DisplayNameFor(model => model.Nome)</div>
                <div class="detail-value">@Html.DisplayFor(model => model.Nome)</div>
            </div>
            <div class="detail-item">
                <div class="detail-label">@Html.DisplayNameFor(model => model.Turma)</div>
                <div class="detail-value">@Html.DisplayFor(model => model.Turma.Nome)</div>
            </div>
            <div class="detail-item">
                <div class="detail-label">@Html.DisplayNameFor(model => model.Telefone)</div>
                <div class="detail-value">@Html.DisplayFor(model => model.Telefone)</div>
            </div>
            <div class="detail-item">
                <div class="detail-label">@Html.DisplayNameFor(model => model.Ativo)</div>
                <div class="detail-value">
                    @if (Model?.Ativo == true)
                    {
                        <span class="badge bg-success">Ativo</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inativo</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="action-buttons-footer">
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-sm btn-edit-subtle">
            Editar
        </a>
        <a asp-action="Index" class="btn btn-sm btn-clear-subtle">
            Voltar
        </a>
    </div>
</div>
