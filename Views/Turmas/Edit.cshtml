@model Acervo_Leitor.Models.Turma

@{
    ViewData["Title"] = "Editar Turma";
}

<div class="form-container">
    <div class="detail-header">
        <h1>Editar Turma</h1>
    </div>

    <div class="form-card">
        <h4>📚 Turma</h4>
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <input type="hidden" asp-for="Id" />
            
            <div class="form-group">
                <label asp-for="Nome" class="control-label">Nome</label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="AnoLetivo" class="control-label">Ano Letivo</label>
                <input asp-for="AnoLetivo" class="form-control" />
                <span asp-validation-for="AnoLetivo" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <div class="form-check">
                    <input class="form-check-input" asp-for="Ativa" />
                    <label class="form-check-label" asp-for="Ativa">
                        @Html.DisplayNameFor(model => model.Ativa)
                    </label>
                </div>
            </div>
            
            <div class="action-buttons-footer">
                <button type="submit" class="btn btn-sm btn-save-subtle">
                    Salvar
                </button>
                <a asp-action="Index" class="btn btn-sm btn-clear-subtle">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
